# ============================================================
# PUBLICA.LA — CHILE (CL)
# ============================================================
# Domínio da loja do Chile (ex: tinta-cl.publica.la)
PUBLICA_STORE_DOMAIN_CL=tinta-cl.publica.la

# Token de autenticação da API do Chile (em /dashboard/settings#api)
PUBLICA_API_TOKEN_CL=seu_api_token_chile

# Chave de assinatura dos webhooks do Chile (em /dashboard/settings#integrations)
PUBLICA_WEBHOOK_SECRET_CL=sua_webhook_secret_chile

# ============================================================
# PUBLICA.LA — PERU (PE)
# ============================================================
# Domínio da loja do Peru (ex: tinta-pe.publica.la)
PUBLICA_STORE_DOMAIN_PE=tinta-pe.publica.la

# Token de autenticação da API do Peru (em /dashboard/settings#api)
PUBLICA_API_TOKEN_PE=seu_api_token_peru

# Chave de assinatura dos webhooks do Peru (em /dashboard/settings#integrations)
PUBLICA_WEBHOOK_SECRET_PE=sua_webhook_secret_peru

# ============================================================
# MAILCHIMP (mesma API Key para ambos os países)
# ============================================================
# API Key (em Account > Extras > API Keys)
MAILCHIMP_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-us1

# ID da Audience do Chile (em Audience > Settings > Audience name and defaults)
MAILCHIMP_AUDIENCE_ID_CL=xxxxxxxxxx

# ID da Audience do Peru
MAILCHIMP_AUDIENCE_ID_PE=xxxxxxxxxx

# ============================================================
# WHATSAPP (Meta Cloud API — mesmo número para ambos os países)
# ============================================================
# Phone Number ID (em Meta Business Manager > WhatsApp > Phone Numbers)
WHATSAPP_PHONE_NUMBER_ID=000000000000000

# Access Token permanente (em Meta Business Manager > System Users)
WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxx

# Nome exato do template de boas-vindas aprovado na Meta
# (em Meta Business Manager > WhatsApp > Message Templates)
WHATSAPP_WELCOME_TEMPLATE=bienvenida_nuevo_cliente

# Código do idioma do template (es para Chile/Peru)
WHATSAPP_TEMPLATE_LANGUAGE=es

# ============================================================
# GOOGLE SHEETS (uma planilha, abas separadas por país)
# ============================================================
# ID da planilha (parte da URL: docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit)
GOOGLE_SPREADSHEET_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Nome da aba do Chile na planilha
GOOGLE_SHEET_NAME_CL=Vendas Chile

# Nome da aba do Peru na planilha
GOOGLE_SHEET_NAME_PE=Vendas Peru

# --- Credenciais da Service Account (escolha UMA das opções abaixo) ---

# OPÇÃO 1 — Nuvem (Railway, Render, etc.)
# Cole aqui o conteúdo JSON completo do arquivo de credenciais, em uma única linha.
# Quando esta variável estiver definida, ela tem prioridade sobre o arquivo.
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"..."}

# OPÇÃO 2 — Local (desenvolvimento)
# Caminho para o arquivo JSON de credenciais baixado do Google Cloud Console.
# Se GOOGLE_SERVICE_ACCOUNT_KEY não estiver definida, este arquivo é usado.
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-credentials.json

# Caminho para o arquivo de credenciais da Service Account (JSON)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-credentials.json

# ============================================================
# SERVIDOR LOCAL
# ============================================================
PORT=3000
